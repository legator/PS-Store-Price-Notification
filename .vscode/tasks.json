{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-app",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PSPriceNotification.csproj",
        "-c",
        "Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-tests",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PSPriceNotification.Tests/PSPriceNotification.Tests.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-tests",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "${workspaceFolder}/PSPriceNotification.Tests/PSPriceNotification.Tests.csproj",
        "-c",
        "Debug"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    }
  ]
}