notification:
  # Windows 10/11 system toast notification (requires no extra setup)
  windows_toast:
    enabled: true

account:
  # Optional PSN account authentication — enables PS Plus pricing and wishlist sync.
  # How to get your NPSSO token:
  #   1. Log in at https://www.playstation.com in your browser.
  #   2. Visit https://ca.account.sony.com/api/v1/ssocookie in the same browser.
  #   3. Copy the 64-character value and paste it below.
  # Tokens are cached in token_cache_file and refreshed automatically (valid ~2 months).
  # npsso: ""
  token_cache_file: "data/psn_tokens.json"

checking:
  # Primary country — always checked first regardless of the countries list.
  primary_country: us

  # Countries to monitor. Omit (or comment out) to check ALL 69 supported countries.
  # countries:
  #   - us
  #   - gb
  #   - de

  # How many countries to fetch simultaneously
  max_concurrency: 5

  # Seconds to wait inside each concurrent slot before the HTTP request
  request_delay: 0.5

storage:
  price_history_db: "data/prices.db"
  # Number of days to keep price history
  max_history_days: 90

logging:
  level: "INFO"
  file: "data/ps_price_check.log"

# Country code → PS Store locale (language-COUNTRY) used to build store URLs.
# Run 'Update-Locales.ps1' to refresh this list from the PlayStation country selector.
